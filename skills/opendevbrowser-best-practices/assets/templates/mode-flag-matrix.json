{
  "schemaVersion": "1.0",
  "daemonPreflight": {
    "command": "npx opendevbrowser status --daemon --output-format json",
    "required": true,
    "statusExpectations": {
      "data.fingerprintCurrent": true
    }
  },
  "modes": [
    {
      "name": "managed",
      "launch": "npx opendevbrowser launch --no-extension",
      "statusProbe": "npx opendevbrowser status --session-id <session-id> --output-format json",
      "requiredFlags": [
        "--no-extension"
      ],
      "statusExpectations": {
        "data.mode": "managed"
      }
    },
    {
      "name": "extension",
      "launch": "npx opendevbrowser launch --extension-only --wait-for-extension",
      "statusProbe": "npx opendevbrowser status --daemon --output-format json",
      "requiredFlags": [
        "--extension-only",
        "--wait-for-extension"
      ],
      "statusExpectations": {
        "data.fingerprintCurrent": true,
        "data.relay.extensionConnected": true,
        "data.relay.extensionHandshakeComplete": true
      },
      "diagnosticPresenceFields": {
        "data.relay.opsConnected": "presence-only; true only when an /ops client is active",
        "data.relay.canvasConnected": "lane-specific; true only when a /canvas client is active",
        "data.relay.cdpConnected": "active-legacy-session-only; false is normal outside legacy /cdp sessions"
      }
    },
    {
      "name": "extension-legacy",
      "launch": "npx opendevbrowser launch --extension-only --extension-legacy --wait-for-extension",
      "statusProbe": "npx opendevbrowser status --daemon --output-format json",
      "requiredFlags": [
        "--extension-only",
        "--extension-legacy",
        "--wait-for-extension"
      ],
      "statusExpectations": {
        "data.fingerprintCurrent": true,
        "data.relay.extensionConnected": true,
        "data.relay.extensionHandshakeComplete": true
      },
      "diagnosticPresenceFields": {
        "data.relay.cdpConnected": "active-legacy-session-only; true only while the legacy /cdp client is connected",
        "data.relay.opsConnected": "presence-only; true only when an /ops client is active",
        "data.relay.canvasConnected": "lane-specific; true only when a /canvas client is active"
      }
    },
    {
      "name": "cdpConnect",
      "connect": "npx opendevbrowser connect --ws-endpoint ws://127.0.0.1:9222/devtools/browser/<id>",
      "statusProbe": "npx opendevbrowser status --session-id <session-id> --output-format json",
      "requiredFlags": [
        "--ws-endpoint"
      ],
      "statusExpectations": {
        "data.mode": "cdpConnect"
      }
    }
  ]
}
