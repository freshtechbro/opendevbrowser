{
  "compilerOptions": {
    // Bundler-mode resolution matches tsup and the generated public-surface and first-contact help imports shipped with the package.
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "rootDir": "src",
    "outDir": "dist",
    // Emit declarations for the shipped runtime surface only; docs/tests consume the checked-in generated manifests separately.
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // Keep the generated public-surface, first-contact help, and docs parity surfaces strongly typed.
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src"]
}
